# RSS source
CR_RSS_URL=https://feeds.feedburner.com/crunchyroll/rss/anime

# Paths
CR_WATCHLIST_PATH=./watchlist.txt
CR_STATE_PATH=./data/state.json
CR_BOT_STATE_PATH=./data/bot_state.json

# Time zone used in email timestamps
CR_TIMEZONE=Europe/Lisbon

# First run behavior:
# - mark_seen: do not notify old feed items on first run
# - notify_all: notify all matching items on first run
CR_BOOTSTRAP_MODE=mark_seen

# Discord bot
DISCORD_BOT_TOKEN=
DISCORD_POLL_MINUTES=15

# Optional: guild id for faster slash-command sync during setup
DISCORD_COMMAND_GUILD_ID=

# SMTP (optional if using Discord only)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-user
SMTP_PASSWORD=your-password
SMTP_FROM=alerts@example.com
SMTP_TO=you@example.com
SMTP_STARTTLS=true

# Discord (optional if using email only)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_USERNAME=Anime Watcher
